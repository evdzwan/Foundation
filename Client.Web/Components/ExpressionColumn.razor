@typeparam TItem
@typeparam TProperty
@inherits Column<TItem>

@code {
    [Parameter, EditorRequired] public required Expression<Func<TItem, TProperty>> Expression { get; set; }

    public override RenderFragment RenderCell(TItem item) => __builder =>
    {
        @Expression.Compile()(item)
    };

    protected override void OnParametersSet()
        => Title ??= Expression.GetPropertyOrDefault()?.Name.Humanize(LetterCasing.Title);
}
