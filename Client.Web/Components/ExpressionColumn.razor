@typeparam TItem where TItem : notnull
@typeparam TValue
@inherits Column<TItem>

@code {
    [Parameter, EditorRequired] public required Expression<Func<TItem, TValue>> Expression { get; set; }
    [Parameter] public RenderFragment<TValue>? ChildContent { get; set; }

    public override RenderFragment RenderCell(TItem item)
    {
        if (ChildContent is { } childContent && Expression.GetPropertyOrDefault() is { CanRead: true } property)
        {
            return childContent((TValue)property.GetValue(item)!);
        }

        return __builder =>
        {
            @item
        };
    }

    protected override void OnParametersSet()
    {
        ChildContent ??= RenderDefaultChildContent();
        Title ??= Expression.GetPropertyOrDefault()?.Name.Humanize(LetterCasing.Title);
    }

    static RenderFragment<TValue> RenderDefaultChildContent() => value => __builder =>
    {
        @value
    };
}
